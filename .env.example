# Server
PORT=5000
HOST=0.0.0.0
NODE_ENV=development

# Frontend / CORS
FRONTEND_URL=http://localhost:3000,https://your-vercel-app.vercel.app

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/purement-pro?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
INTERNAL_API_KEY=replace-with-a-long-random-internal-api-key

# Email / Brevo
BREVO_API_KEY=replace-with-your-brevo-api-key
MAIL_FROM_EMAIL=info@example.com
MAIL_FROM_NAME=Purement Pro

# Seed admin user
SEED_ADMIN_FIRST_NAME=Admin
SEED_ADMIN_LAST_NAME=User
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
